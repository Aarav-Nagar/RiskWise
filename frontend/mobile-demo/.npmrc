# Clerk (@clerk/clerk-expo -> @clerk/shared) declares a peerOptional react-dom
# newer than the react/react-dom 19.1.0 this app pins. npm 11 (local) tolerates
# it, but the EAS builder's npm 10 resolved a nested react-dom@19.2.8 that was
# absent from the lock, so `npm ci` hard-failed (build 3feca3fb, 2026-07-23).
# legacy-peer-deps makes peer resolution deterministic across npm versions so the
# committed lock matches what EAS installs. Runtime is unaffected.
legacy-peer-deps=true
