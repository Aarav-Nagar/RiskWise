{
  "name": "riskwise-mobile-demo",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "web": "expo start --web",
    "export:web": "expo export -p web --output-dir dist-web",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "qa:smoke": "npm run export:web && playwright test --config=playwright.config.cjs",
    "qa:smoke:headed": "npm run export:web && playwright test --config=playwright.config.cjs --headed",
    "doctor": "npx expo-doctor",
    "check:production-env": "node ./scripts/validate-production-env.cjs",
    "eas-build-pre-install": "node ./scripts/validate-production-env.cjs",
    "build:android:preview": "npx eas-cli build --platform android --profile preview",
    "build:ios:testflight": "npx eas-cli build --platform ios --profile testflight",
    "build:ios:production": "npx eas-cli build --platform ios --profile production",
    "submit:ios:testflight": "npx eas-cli submit --platform ios --profile testflight"
  },
  "dependencies": {
    "@clerk/clerk-expo": "^2.19.31",
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.0.3",
    "@sentry/react-native": "~7.2.0",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.10",
    "expo": "^54.0.35",
    "expo-asset": "~12.0.13",
    "expo-auth-session": "~7.0.11",
    "expo-clipboard": "~8.0.8",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.12",
    "expo-image-picker": "~17.0.11",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.11",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@playwright/test": "^1.60.0",
    "eslint": "^9.39.5",
    "typescript": "~5.9.2"
  }
}
