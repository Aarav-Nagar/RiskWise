APP_ENV=development
APP_STORAGE_PROVIDER=demo

# Local services
PORT=4000
CLIENT_URL=http://localhost:5173
EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Clerk auth
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_ISSUER=
CLERK_JWKS_URL=
CLERK_AUDIENCE=
CLERK_AUTHORIZED_PARTIES=
CLERK_JWT_LEEWAY_SECONDS=10
FRONTEND_ALLOWED_ORIGINS=http://127.0.0.1:8081,http://localhost:8081

# Cloud database
MONGODB_URI=
MONGODB_DATABASE=finance_app

# AI sidecar
LLM_PROVIDER_ORDER=ollama,gemini,openai,fallback
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_VERSION=v1beta
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
LLM_REQUEST_TIMEOUT_SECONDS=30.0
LLM_PROVIDER_COOLDOWN_SECONDS=300
LLM_TEMPERATURE=0.35
LLM_MAX_OUTPUT_TOKENS=360
OLLAMA_KEEP_ALIVE=10m

# Market data providers
MARKET_DATA_PROVIDER=hybrid
FMP_API_KEY=
ALPHA_VANTAGE_API_KEY=
ENABLE_YFINANCE_OPTIONS=true
POLYGON_API_KEY=
MASSIVE_API_KEY=
MASSIVE_BASE_URL=https://api.massive.com
POLYGON_BASE_URL=https://api.polygon.io
TRADIER_API_KEY=

# Monitoring
SENTRY_DSN=

# GitHub Education / deployment helpers
DOPPLER_PROJECT=options-risk-check
DOPPLER_CONFIG=dev
EXPO_TOKEN=
APPLE_TEAM_ID=
IOS_BUNDLE_IDENTIFIER=com.aaravnagar.riskwise
